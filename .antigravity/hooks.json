{
  "aiox-sentinel": {
    "enabled": true,
    "PreToolUse": [
      {
        "matcher": "run_command|view_file|write_to_file|replace_file_content|multi_replace_file_content|list_dir|find_by_name|grep_search|invoke_subagent|define_subagent|send_message|manage_subagents",
        "hooks": [
          {
            "type": "command",
            "command": "node \".aiox-core/infrastructure/scripts/antigravity-sentinel-hook.js\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}